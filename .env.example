DATABASE_URL=
DB_SYNC=true

# Login local usado apenas quando a aplicacao estiver rodando com SQLite
# e sem DATABASE_URL. O mesmo valor entra como usuario administrativo
# e como matricula do comprador.
LOCAL_LOGIN_USUARIO=seu_usuario
LOCAL_LOGIN_SENHA=sua_senha
LOCAL_LOGIN_NOME=Seu Nome
LOCAL_LOGIN_EMAIL=seu_usuario@local.test
LOCAL_LOGIN_PERFIL=admin